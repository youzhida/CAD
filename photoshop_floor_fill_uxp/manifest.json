{
  "manifestVersion": 4,
  "id": "com.youzhida.floor-fill-auto",
  "name": "Floor Fill Auto",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "23.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "floor-fill-panel",
      "label": {
        "default": "Floor Fill Auto"
      },
      "minimumSize": {
        "width": 280,
        "height": 220
      },
      "preferredDockedSize": {
        "width": 320,
        "height": 260
      },
      "preferredFloatingSize": {
        "width": 360,
        "height": 300
      },
      "maximumSize": {
        "width": 560,
        "height": 720
      }
    }
  ]
}
